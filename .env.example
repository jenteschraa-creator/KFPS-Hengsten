# =============================================================================
# KFPS Hengsten Platform — Environment Variables
# Kopieer dit bestand naar .env.local en vul de echte waarden in.
# .env.local staat in .gitignore en wordt NOOIT gecommit.
# =============================================================================

# Supabase project URL (te vinden in Supabase Dashboard > Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon / public key (veilig voor frontend — beveilig via RLS)
SUPABASE_ANON_KEY=your_anon_key_here

# ⚠️  HIERONDER STAAT WAT JE NOOIT IN DEZE REPO MAG ZETTEN:
# SUPABASE_SERVICE_ROLE_KEY=...  ← ALLEEN voor server-side / Edge Functions
# DATABASE_PASSWORD=...          ← ALLEEN voor directe DB-verbinding via pooler
